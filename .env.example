# Copy this file to .env and fill in real values.
# Required vars cause the API to hard-fail at startup if missing.

# HTTP
PORT=8080

# Database (Postgres) — required
# Local default uses host port 5433 to avoid clashes with other Postgres
# instances on 5432. Inside Docker the service still listens on 5432.
DATABASE_URL=postgres://portfolio:portfolio@localhost:5433/portfolio?sslmode=disable

# Auth — required
# JWT_SECRET should be a long random string (32+ bytes, e.g. `openssl rand -hex 32`).
# ADMIN_PASSWORD holds a bcrypt hash of the admin passphrase. Generate one
# interactively with `make hashpw`. The literal `$` characters in the hash
# are fine — cmd/api loads .env itself and does not pass it through Make.
JWT_SECRET=replace-me-with-a-long-random-string
ADMIN_PASSWORD=$2a$10$replace.with.real.bcrypt.hash.via.make.hashpw

# Cookie hardening — set COOKIE_SECURE=true behind HTTPS in production so the
# admin_token cookie carries the Secure attribute. Leave false in local dev.
COOKIE_SECURE=false

# Cloudflare R2 — required
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=portfolio-assets
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# Object key of the resume PDF in the bucket. GET /api/v1/profile/resume
# presigns this key when R2 is configured (real creds + a non-placeholder
# endpoint); otherwise it falls back to profile.resume_url.
R2_RESUME_KEY=resume.pdf
# Public base URL for the bucket. Used to build the stable, public URLs stored
# for uploaded assets (covers, blog images). REQUIRED for assets to actually
# render in the browser — when empty, PublicURL falls back to the path-style R2
# API endpoint which requires SigV4 auth and returns 400 to anonymous GETs.
# Dev: enable Public Access on the R2 bucket and paste the `https://pub-<hash>.r2.dev` URL here (no trailing slash).
# Prod: replace with the custom domain bound to the bucket at Fly.io cutover (SCRUM-55).
R2_PUBLIC_BASE_URL=

# Contact form email (Resend) — optional.
# When RESEND_API_KEY and CONTACT_TO_EMAIL are set, POST /api/v1/contact sends
# via Resend. Otherwise the message is logged (LogMailer) so the form still
# works locally. CONTACT_FROM_EMAIL must be a Resend-verified sender; the
# onboarding@resend.dev default works for testing.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
