# Copy this file to .env and fill in real values.
# Required vars cause the API to hard-fail at startup if missing.

# HTTP
PORT=8080

# Database (Postgres) — required
# Local default uses host port 5433 to avoid clashes with other Postgres
# instances on 5432. Inside Docker the service still listens on 5432.
DATABASE_URL=postgres://portfolio:portfolio@localhost:5433/portfolio?sslmode=disable

# Auth — required
JWT_SECRET=replace-me-with-a-long-random-string
ADMIN_PASSWORD=replace-me-with-a-bcrypt-hash

# Cloudflare R2 — required
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=portfolio-assets
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
